# Supabase Configuration (client-safe; VITE_ vars are bundled into the SPA)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Fuel Prices API URL
# For development: leave empty to use Vite proxy (localhost:3001)
# For production: set to your deployed API URL
# Example: VITE_FUEL_API_URL=https://api.fixup.ge
VITE_FUEL_API_URL=

# Build-time sitemap generation
# Used by scripts/generate-sitemap.mjs (runs via `prebuild` before `vite build`).
# SERVICE ROLE key is required to bypass RLS and read all active rows.
# DO NOT expose this on the client — only set it in CI / hosting build env.
# If missing at build time, the script no-ops and keeps the existing public/sitemap.xml.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
