# Cache-Control headers (read by Netlify / Cloudflare Pages style hosting).
# If the host ignores this file it is simply a no-op — safe to ship.

# Hashed build assets (index-XXXX.js / .css) — the filename changes on every
# rebuild, so caching forever is safe and never serves stale code.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static images with FIXED names — moderate cache (30 days). Not "immutable"
# so that replacing one (same filename) refreshes within a month.
/icons/*
  Cache-Control: public, max-age=2592000
/lovable-uploads/*
  Cache-Control: public, max-age=2592000
/fuel-company-logos/*
  Cache-Control: public, max-age=2592000

# App shell + service worker must stay fresh so new deploys/SW updates apply.
/index.html
  Cache-Control: no-cache
/sw.js
  Cache-Control: no-cache
/registerSW.js
  Cache-Control: no-cache
